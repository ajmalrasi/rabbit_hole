# ==========================================================================
# Rabbit Hole backend configuration
# Copy this file to `.env` and adjust the values for your deployment.
# ==========================================================================

# ----- Application -----
APP_NAME="Rabbit Hole"
APP_ENV=production
LOG_LEVEL=INFO
# Comma separated list of allowed CORS origins (use * for all)
CORS_ORIGINS=*

# ----- Database -----
# These values are also consumed by the Postgres container in docker-compose.
POSTGRES_USER=rabbit
POSTGRES_PASSWORD=rabbit_secret_change_me
POSTGRES_DB=rabbit_hole
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ----- LLM provider selection -----
# Provider used for text generation: ollama | openai | gemini
LLM_PROVIDER=ollama
# Provider used for embeddings: ollama | openai | gemini
EMBEDDING_PROVIDER=ollama

# ----- Ollama (local, runs great on Jetson Orin Nano) -----
# When the backend runs in Docker, the Jetson host is reachable on host.docker.internal
# or via the LAN address of the device itself.
OLLAMA_BASE_URL=http://192.168.3.30:11434
# Use the smallest model that fits GPU memory.
# On Jetson Orin Nano (8GB unified): llama3.2:1b works; qwen3.5:4b is too large.
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ----- OpenAI (or any OpenAI-compatible endpoint) -----
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ----- Gemini (uses the OpenAI-compatible endpoint) -----
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ----- Embeddings -----
# Vector dimension MUST match the embedding model you use:
#   nomic-embed-text          -> 768
#   text-embedding-004        -> 768
#   text-embedding-3-small    -> 1536
EMBEDDING_DIM=768
# Cosine distance below which two rabbit holes are considered duplicates (0..2)
DEDUP_DISTANCE_THRESHOLD=0.15

# ----- Curiosity gating -----
MIN_CURIOSITY_SCORE=6.0
MIN_HIDDEN_MECHANISM_SCORE=6.0

# ----- RSS feed cache -----
# Directory where raw feed XML is cached. Mapped to a Docker volume below.
# Set to "" to disable disk caching (fetches every run).
RSS_CACHE_DIR=/data/rss_cache
# Minutes before a cached feed is considered stale and re-fetched.
# Feeds that support ETag/If-Modified-Since get a free 304 check first.
RSS_CACHE_TTL_MINUTES=60

# ----- Pipeline / scheduler -----
# Once-daily pipeline run (UTC): ingest RSS → score → generate → feed.
DAILY_PIPELINE_HOUR=6
DAILY_PIPELINE_MINUTE=0
# Max articles per batch (each loop iteration when draining)
MAX_ARTICLES_PER_RUN=15
# /admin/pipeline/process loops until NEW+SCORED queues empty when true
PIPELINE_DRAIN_ON_PROCESS=true
# Run the pipeline once shortly after startup (set false for daily-only rhythm)
RUN_ON_STARTUP=false
# How many rabbit holes to include in the daily feed
DAILY_FEED_SIZE=50
